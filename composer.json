{
  "name": "solophp/http-client",
  "type": "library",
  "description": "PSR-18 HTTP client",
  "keywords": ["psr-18","php","http-client"],
  "license": "MIT",
  "authors": [
    {
      "name": "Vitaliy Olos",
      "email": "vedastudio@gmail.com"
    }
  ],
  "autoload": {
    "psr-4": {
     "Solo\\HttpClient\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Solo\\HttpClient\\Tests\\": "tests/"
    }
  },
  "require": {
    "php": "^8.1",
    "guzzlehttp/guzzle": "^7.9",
    "psr/log": "^3.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.0",
    "squizlabs/php_codesniffer": "^3.7"
  },
  "scripts": {
    "test": "phpunit",
    "cs": "phpcs --standard=PSR12 src/ tests/",
    "cs-fix": "phpcbf --standard=PSR12 src/ tests/"
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
